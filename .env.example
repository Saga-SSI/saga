# Cursor SDK — https://cursor.com/docs/sdk/typescript
# User key: https://cursor.com/dashboard/integrations
# Service account: Team settings → Service accounts
CURSOR_API_KEY=

# Mintlify — https://www.mintlify.com/docs/guides/assistant-embed
# Domain slug from dashboard URL (dashboard.mintlify.com/org/<domain>)
MINTLIFY_DOMAIN=
# Assistant API key (mint_dsc_…) from Mintlify dashboard → API keys
MINTLIFY_ASSISTANT_TOKEN=
# Deployed docs URL (local preview defaults to http://localhost:3333)
MINTLIFY_DOCS_URL=http://localhost:3333
