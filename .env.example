# Cursor SDK — https://cursor.com/docs/sdk/typescript
# User key: https://cursor.com/dashboard/integrations
# Service account: Team settings → Service accounts
CURSOR_API_KEY=

# Mintlify — https://www.mintlify.com/docs/guides/assistant-embed
# Domain slug from dashboard URL (dashboard.mintlify.com/org/<domain>)
MINTLIFY_DOMAIN=
# Assistant API key (mint_dsc_…) from Mintlify dashboard → API keys
MINTLIFY_ASSISTANT_TOKEN=
# Public docs URL on your app (proxied to Mintlify via /docs rewrites in next.config.mjs)
# Use your Next.js origin + /docs, e.g. http://localhost:3000/docs
MINTLIFY_DOCS_URL=http://localhost:3000/docs
# Local Mintlify preview server (npm run docs:dev). In dev, Next /docs proxies here instead of production.
MINTLIFY_LOCAL_DEV_URL=http://localhost:3333
# After enabling "Host at /docs" in Mintlify dashboard, set this to true for production rewrites:
# MINTLIFY_DOCS_SUBPATH=true
# Optional: override Mintlify proxy target
# MINTLIFY_REWRITE_URL=https://your-subdomain.mintlify.dev/docs
