{
  "name": "saga",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:convex": "convex dev",
    "dev:all": "concurrently -n app,convex -c blue,magenta \"npm run dev\" \"npm run dev:convex\"",
    "dev:with-docs": "concurrently -n app,docs -c blue,green \"npm run dev\" \"npm run docs:dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cursor:ask": "tsx --env-file=.env.local scripts/ask-cursor.ts",
    "docs:dev": "npm run dev --prefix docs",
    "docs:validate": "npm run validate --prefix docs"
  },
  "dependencies": {
    "@ai-sdk/react": "^1.2.12",
    "@clerk/nextjs": "^6.25.1",
    "@convex-dev/presence": "^0.3.0",
    "@cursor/sdk": "^1.0.13",
    "ai": "^4.3.19",
    "convex": "^1.25.2",
    "country-flag-icons": "^1.6.17",
    "framer-motion": "^12.40.0",
    "next": "^14.2.25",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.2.1",
    "eslint": "^8",
    "eslint-config-next": "^14.2.25",
    "mint": "^4.0.1180",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
