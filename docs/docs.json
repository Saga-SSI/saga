{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Saga",
  "description": "Documentation for Saga — communities building on the interweb.",
  "colors": {
    "primary": "#E8E4DC",
    "light": "#E8E4DC",
    "dark": "#1C1C1C"
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#1C1C1C"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo.svg",
    "href": "/docs"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get started",
            "pages": ["index", "quickstart"]
          }
        ]
      },
      {
        "tab": "Platform",
        "groups": [
          {
            "group": "Platform",
            "pages": [
              "platform/dashboard",
              "platform/cursor-agent",
              "platform/mintlify"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Documentation",
        "href": "/documentation"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "/dashboard"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com"
    }
  }
}
